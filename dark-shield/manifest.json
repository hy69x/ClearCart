{
  "manifest_version": 3,
  "name": "DarkShield",
  "version": "1.0",
  "description": "Detects dark patterns on Indian shopping websites in real time.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "*://*.amazon.in/*",
    "*://*.flipkart.com/*",
    "*://*.blinkit.com/*",
    "*://*.meesho.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.in/*",
        "*://*.flipkart.com/*",
        "*://*.blinkit.com/*",
        "*://*.meesho.com/*"
      ],
      "css": ["styles.css"],
      "js": ["patterns.js", "content.js"],
      "run_at": "document_end"
    }
  ]
}